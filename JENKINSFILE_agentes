//JENKINSFILE_agentes CI

def baseUrlApi = ""

pipeline {
    
    agent { label 'built-in' }
    
    options {
        skipDefaultCheckout true
    }
    
    stages {
        
        stage('Get Code') {
            agent { label 'built-in' }
            steps {
                deleteDir()
                
                git branch: 'develop', url: 'https://github.com/AntonioMLUnir/Practica1.4'
                
                sh '''
                    hostname
                    whoami 
                '''
                stash name:'code', includes:'**'
            }
        }
               
        stage('Static') {
            parallel {
                stage('Flake8') {
                    agent {label 'nodo-linux1'}
                    steps {
                        unstash name:'code'
                        sh '''
                            whoami
                            hostname
                            
                            export PYTHONPATH=${WORKSPACE}
                            python3 -m flake8 src/ --exit-zero --format=pylint --output-file=flake8_report_agentes.txt
                        '''
                        stash name:'flake8-report', includes:'flake8_report_agentes.txt'
                    }
                }
                
                stage('Seguridad') {
                    agent {label 'nodo-linux1'}
                    steps {
                        unstash name:'code'
                        sh '''
                            whoami
                            hostname
                            
                            export PYTHONPATH=${WORKSPACE}
                            
                            bandit -r src/ -f txt -o bandit_report_agentes.txt
                        '''
                        stash name:'bandit-report', includes:'bandit_report_agentes.txt'
                    }
                }
            }
            
            post {
                always {
                    unstash 'flake8-report'
                    unstash 'bandit-report'
                    archiveArtifacts artifacts: 'flake8_report_agentes.txt, bandit_report_agentes.txt', fingerprint: true
                }
            }
        }
        
        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                unstash name:'code'
                sh '''
                    whoami
                    hostname
                    
                    sam build
                    sam validate --region us-east-1
                    sam deploy --config-env staging --no-confirm-changeset --resolve-s3 --no-fail-on-empty-changeset
                '''
                
                script {
                    baseUrlApi = sh(
                        script: "aws cloudformation describe-stacks --region us-east-1 --stack-name staging-todo-list-aws --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --output text",
                        returnStdout: true
                    ).trim()
                }
            }
        }
        
        stage('Rest Test') {
            agent {label 'nodo-linux2'}
            steps {
                 catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                     unstash name:'code'
                     sh """
                        whoami
                        hostname
                        
                        export PYTHONPATH=${WORKSPACE}
                        export BASE_URL=${baseUrlApi}

                        pytest -s -v --junitxml=rest_report_agentes.xml test/integration/todoApiTest.py
                    """
                    
                    junit 'rest_report_agentes.xml'
                }
            }
        }
        
        stage('Promoción') {
            agent { label 'built-in' }
            when {
                expression { currentBuild.result == 'SUCCESS' || currentBuild.result == null }
            }
            steps {
                withCredentials([usernamePassword(credentialsId:'Jenkins-GitHub', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    unstash name:'code'
                    sh '''
                        whoami
                        hostname
                    
                        git remote set-url origin https://${USER}:${PASS}@github.com/AntonioMLUnir/Practica1.4.git
                        git fetch origin master
                        git checkout master
                        git reset --hard origin/master
                    
                        git merge origin/develop --no-commit --no-ff || true
                    
                        git checkout HEAD -- JENKINSFILE
                        git checkout HEAD -- JENKINSFILE_agentes
                    
                        git add .
                        git commit -m "Merge sin JENKINSFILES"
                        git push origin master
                    '''
                }
            }
        }
    }
}  
